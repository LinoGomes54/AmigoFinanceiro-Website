# Porta em que a API sobe
PORT=3333

# Ambiente: development | production | test
NODE_ENV=development

# Origem do frontend liberada no CORS
CORS_ORIGIN=http://localhost:5173

# Segredo de assinatura dos tokens JWT.
# Em produção, gere um valor aleatório longo e nunca reaproveite este exemplo.
JWT_SECRET=troque-este-valor-em-producao

# Validade do token de sessão
JWT_EXPIRES_IN=7d
